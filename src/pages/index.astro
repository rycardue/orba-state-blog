---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mallorca Immobilien Ratgeber auf Deutsch | Orba State</title>
  <meta name="description" content="Expertenwissen für deutschsprachige Immobilienkäufer auf Mallorca: Steuern, Kosten, Gebiete, Tipps und Fallstricke. Kostenlos und auf Deutsch." />
  <link rel="canonical" href="https://orbastate.com/blog" />
  <meta property="og:title" content="Mallorca Immobilien Ratgeber auf Deutsch | Orba State" />
  <meta property="og:description" content="Expertenwissen für deutschsprachige Käufer auf Mallorca." />
  <meta property="og:url" content="https://orbastate.com/blog" />
  <meta property="og:type" content="website" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Georgia, serif;
      background: #fafaf9;
      color: #1a1a1a;
    }

    header {
      background: #0a0a0a;
      padding: 1rem 2rem;
    }
    header a {
      color: #d4af6a;
      text-decoration: none;
      font-size: 1.1rem;
      font-weight: 600;
      letter-spacing: 0.05em;
    }
    header nav {
      max-width: 900px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    header nav .portal-link {
      color: #888;
      font-size: 0.9rem;
      font-weight: 400;
    }

    .hero {
      background: #0a0a0a;
      color: #fff;
      padding: 4rem 2rem 3rem;
      text-align: center;
    }
    .hero h1 {
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      font-weight: 700;
      margin-bottom: 1rem;
      line-height: 1.2;
    }
    .hero h1 span { color: #d4af6a; }
    .hero p {
      color: #aaa;
      font-size: 1.05rem;
      max-width: 560px;
      margin: 0 auto;
    }

    main {
      max-width: 900px;
      margin: 0 auto;
      padding: 3rem 2rem 6rem;
    }

    .posts-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1.5rem;
    }

    .post-card {
      background: #fff;
      border: 1px solid #e5e5e5;
      border-radius: 8px;
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      transition: box-shadow 0.15s, border-color 0.15s;
      text-decoration: none;
      color: inherit;
    }
    .post-card:hover {
      box-shadow: 0 4px 20px rgba(0,0,0,0.08);
      border-color: #d4af6a;
    }

    .post-date {
      font-size: 0.8rem;
      color: #aaa;
      margin-bottom: 0.6rem;
    }
    .post-title {
      font-size: 1.05rem;
      font-weight: 700;
      line-height: 1.3;
      margin-bottom: 0.6rem;
      color: #0a0a0a;
    }
    .post-desc {
      font-size: 0.875rem;
      color: #666;
      line-height: 1.5;
      flex: 1;
    }
    .post-link {
      display: inline-block;
      margin-top: 1rem;
      font-size: 0.85rem;
      color: #b8943e;
      font-weight: 600;
    }

    .empty {
      text-align: center;
      padding: 4rem 0;
      color: #888;
    }

    footer {
      text-align: center;
      padding: 2rem;
      color: #aaa;
      font-size: 0.8rem;
      border-top: 1px solid #e5e5e5;
    }
    footer a { color: #888; text-decoration: none; }
  </style>
</head>
<body>
  <header>
    <nav>
      <a href="https://orbastate.com">Orba State</a>
      <a class="portal-link" href="https://orbastate.com">Zum Portal →</a>
    </nav>
  </header>

  <div class="hero">
    <h1>Immobilien Mallorca<br /><span>Ratgeber auf Deutsch</span></h1>
    <p>Alles was Sie wissen müssen, bevor Sie auf Mallorca kaufen. Ehrlich, praktisch, auf Deutsch.</p>
  </div>

  <main>
    {posts.length === 0 ? (
      <div class="empty">
        <p>Artikel erscheinen bald. Bleiben Sie dran.</p>
      </div>
    ) : (
      <div class="posts-grid">
        {posts.map(post => (
          <a class="post-card" href={`/blog/${post.id}`}>
            <div class="post-date">
              {post.data.date.toLocaleDateString('de-DE', { year: 'numeric', month: 'long', day: 'numeric' })}
            </div>
            <div class="post-title">{post.data.title}</div>
            <div class="post-desc">{post.data.description}</div>
            <span class="post-link">Weiterlesen →</span>
          </a>
        ))}
      </div>
    )}
  </main>

  <footer>
    <p>&copy; {new Date().getFullYear()} Orba State &nbsp;|&nbsp; <a href="https://orbastate.com">orbastate.com</a></p>
  </footer>
</body>
</html>
